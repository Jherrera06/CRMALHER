# CRM ALHER · Variables privadas de Firebase Functions
# Copiar este archivo como .env dentro de la carpeta functions/ y completar los valores reales.
# No subir tokens reales al ZIP ni compartir capturas con tokens visibles.

# WhatsApp / Meta Cloud API
WHATSAPP_VERIFY_TOKEN=ALHER.COM
WHATSAPP_TOKEN=PEGAR_TOKEN_NUEVO_DE_META
WHATSAPP_PHONE_NUMBER_ID=113013548315130
WHATSAPP_API_VERSION=v23.0
DEFAULT_RESPONSABLE=superadm
ALHER_SALES_BOT_ENABLED=true

# Control de cartones · Google Cloud Vision API
# Si solo tenés API Key de Google Cloud, esta URL es fija.
CARTONES_SCAN_API_URL=https://vision.googleapis.com/v1/images:annotate
CARTONES_SCAN_API_KEY=PEGAR_API_KEY_DE_GOOGLE_CLOUD
CARTONES_SCAN_API_KEY_HEADER=key

# Opcional: protege endpoints internos /api si decidís exigir clave compartida.
# ALHER_API_SHARED_SECRET=PEGAR_CLAVE_INTERNA_OPCIONAL

# IMPORTANTE GOOGLE VISION: para evitar el error de llamadas no registradas,
# la Function envía esta API Key como parámetro ?key= en la URL, no como Bearer.
